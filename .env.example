# Database Configuration
DATABASE_URL=postgresql://dhm_user:dhm_password@postgres:5432/device_health_db
DB_POOL_SIZE=20
DB_ECHO=False

# FastAPI Configuration
APP_NAME=Device Health Monitoring System
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=production
SECRET_KEY=your-secret-key-change-in-production

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_ENABLED=True

# SMTP Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=alerts@devicehealth.com
EMAIL_ALERTS_ENABLED=True

# APScheduler Configuration
SCHEDULER_ENABLED=True
ANALYZER_INTERVAL_SECONDS=300
RCA_INTERVAL_SECONDS=600

# Battery Thresholds
BATTERY_WARNING_THRESHOLD=40
BATTERY_CRITICAL_THRESHOLD=20
BATTERY_DEGRADATION_WARNING=10
BATTERY_DEGRADATION_CRITICAL=20

# Temperature Thresholds (Celsius)
TEMP_MIN_THRESHOLD=-20
TEMP_MAX_THRESHOLD=80
TEMP_WARNING_THRESHOLD=75

# Firmware Configuration
FIRMWARE_UPDATE_CHECK_ENABLED=True
FIRMWARE_EOL_DAYS=180

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_ENABLED=True
LOG_LEVEL=INFO

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Feature Flags
ENABLE_ADVANCED_RCA=True
ENABLE_FLEET_AGGREGATION=True
